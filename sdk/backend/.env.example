# Azure OpenAI
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_KEY=replace-me
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_CHAT_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=text-embedding-3-large

# Azure Blob Storage artifacts
# Local development uses DefaultAzureCredential through `az login`.
# Production uses the Container Apps managed identity.
AZURE_STORAGE_ACCOUNT_URL=https://your-storage-account.blob.core.windows.net
AZURE_BLOB_CONTAINER_NAME=rag-artifacts
FAISS_INDEX_BLOB_NAME=hr-policy.faiss.index
CHUNK_METADATA_BLOB_NAME=hr-policy-chunks.parquet
BM25_BLOB_NAME=bm25.pkl

# Local runtime tuning
LOCAL_ARTIFACT_DIR=data/artifacts
LOG_LEVEL=INFO
RETRIEVAL_TOP_K_DENSE=20
RETRIEVAL_TOP_K_LEXICAL=20
RETRIEVAL_TOP_K_FINAL=8
RRF_K=60
